# Static website gitignore

# npm dependencies
node_modules/

# Build outputs
dist/
build/
out/

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor directories and files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Temporary files
*.tmp
*.temp
*.bak
*~

# Generated files from macOS
.AppleDouble
.LSOverride

# Ignore local environment files
.env

# Ignore Sass cache if used
.sass-cache/

# Ignore coverage outputs
coverage/
